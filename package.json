{
  "name": "pickcat-reborn",
  "version": "0.1.0",
  "private": true,
  "description": "A frontend-first Pickcat community reconstruction prototype.",
  "main": "desktop/main.cjs",
  "scripts": {
    "dev": "node serve.mjs",
    "check": "node --check app.js",
    "desktop": "electron .",
    "dist:win": "electron-builder --win portable",
    "android:sync": "node tools/sync-android-assets.mjs",
    "android:build": "pnpm run android:sync && android\\gradlew.bat -p android assembleDebug"
  },
  "devDependencies": {
    "electron": "^37.5.1",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "cn.pickcat.reborn",
    "productName": "Pickcat Reborn",
    "asar": true,
    "files": [
      "desktop/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".",
        "to": "app",
        "filter": [
          "index.html",
          "app.js",
          "styles.css",
          "manifest.webmanifest",
          "public/**"
        ]
      }
    ],
    "directories": {
      "output": "release/windows"
    },
    "win": {
      "target": "portable"
    }
  }
}
